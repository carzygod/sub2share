generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  disabled
  banned
}

enum RoleCode {
  buyer
  supplier
  operator
  admin
}

enum AuthProvider {
  google
  x
}

enum ResourceType {
  codex
  claude_code
  gemini
  antigravity
}

enum ProductStatus {
  draft
  active
  offline
}

enum ProductBillingMode {
  pay_as_you_go
  daily
  weekly
  monthly
}

enum OrderStatus {
  pending
  paid
  provisioning
  active
  failed
  refunding
  refunded
  expired
  cancelled
  closed
}

enum RentalStatus {
  active
  low_balance
  limited
  suspended
  expired
  refunded
  closed
}

enum WalletTransactionType {
  recharge
  freeze
  unfreeze
  consume
  refund
  withdrawal_freeze
  withdrawal_paid
  adjustment
}

enum SupplierResourceStatus {
  pending
  testing
  online
  busy
  paused
  abnormal
  disabled
}

enum SupplierLevel {
  L0
  L1
  L2
  L3
  L4
}

enum UsageStatus {
  pending
  billed
  refunded
  ignored
  disputed
}

enum SettlementStatus {
  pending
  frozen
  available
  withdrawn
  cancelled
}

enum WithdrawalStatus {
  pending
  approved
  rejected
  paid
  cancelled
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  phone        String?
  passwordHash String
  displayName  String?
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  roles      UserRole[]
  wallet     WalletAccount?
  orders     Order[]
  rentals    Rental[]
  supplier   Supplier?
  apiKeys    ApiKey[]
  auditLogs  AuditLog[]
  identities UserIdentity[]
  proxyRequestLogs ProxyRequestLog[]
  systemHealthSnapshots SystemHealthSnapshot[]
}

model UserIdentity {
  id             String       @id @default(uuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  email          String?
  displayName    String?
  avatarUrl      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([email])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  role      RoleCode
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model WalletAccount {
  id               String   @id @default(uuid())
  userId           String   @unique
  currency         String   @default("USD")
  availableBalance Decimal  @default(0) @db.Decimal(18, 6)
  frozenBalance    Decimal  @default(0) @db.Decimal(18, 6)
  totalRecharged   Decimal  @default(0) @db.Decimal(18, 6)
  totalSpent       Decimal  @default(0) @db.Decimal(18, 6)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id           String                @id @default(uuid())
  walletId     String
  type         WalletTransactionType
  amount       Decimal               @db.Decimal(18, 6)
  balanceAfter Decimal               @db.Decimal(18, 6)
  currency     String                @default("USD")
  refType      String?
  refId        String?
  note         String?
  createdAt    DateTime              @default(now())

  wallet WalletAccount @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([refType, refId])
}

model Product {
  id           String             @id @default(uuid())
  name         String
  resourceType ResourceType
  billingMode  ProductBillingMode
  description  String?
  status       ProductStatus      @default(draft)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  prices  ProductPrice[]
  orders  OrderItem[]
  rentals Rental[]
}

model ProductPrice {
  id             String        @id @default(uuid())
  productId      String
  tierCode       String
  displayName    String
  discountRate   Decimal       @default(0.2) @db.Decimal(8, 4)
  tierMultiplier Decimal       @default(1) @db.Decimal(8, 4)
  fixedPrice     Decimal?      @db.Decimal(18, 6)
  durationDays   Int?
  maxConcurrency Int           @default(1)
  rpmLimit       Int?
  tpmLimit       Int?
  requestLimit   Int?
  spendLimit     Decimal?      @db.Decimal(18, 6)
  status         ProductStatus @default(active)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, tierCode])
}

model Order {
  id             String      @id @default(uuid())
  userId         String
  idempotencyKey String?
  status         OrderStatus @default(pending)
  currency       String      @default("USD")
  totalAmount    Decimal     @db.Decimal(18, 6)
  paidAmount     Decimal     @default(0) @db.Decimal(18, 6)
  paymentRef     String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  items   OrderItem[]
  rentals Rental[]
  statusHistory OrderStatusHistory[]

  @@unique([userId, idempotencyKey])
}

model OrderStatusHistory {
  id          String      @id @default(uuid())
  orderId     String
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  actorUserId String?
  reason      String?
  meta        Json?
  createdAt   DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([actorUserId, createdAt])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  priceId   String?
  quantity  Int     @default(1)
  amount    Decimal @db.Decimal(18, 6)
  meta      Json?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model Rental {
  id           String       @id @default(uuid())
  userId       String
  orderId      String
  productId    String
  resourceType ResourceType
  status       RentalStatus @default(active)
  startsAt     DateTime     @default(now())
  endsAt       DateTime?
  sub2UserId   String?
  sub2KeyId    String?
  sub2KeyHash  String?
  endpointUrl  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  order   Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  product Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  limits  RentalLimit?
  apiKeys ApiKey[]
  usages  UsageRecord[]
  proxyRequestLogs ProxyRequestLog[]
}

model RentalLimit {
  id             String   @id @default(uuid())
  rentalId       String   @unique
  maxConcurrency Int      @default(1)
  rpmLimit       Int?
  tpmLimit       Int?
  requestLimit   Int?
  spendLimit     Decimal? @db.Decimal(18, 6)
  remainingSpend Decimal? @db.Decimal(18, 6)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rental Rental @relation(fields: [rentalId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  rentalId   String?
  name       String
  keyPrefix  String
  keyHash    String
  status     String    @default("active")
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rental Rental? @relation(fields: [rentalId], references: [id], onDelete: SetNull)
  proxyRequestLogs ProxyRequestLog[]
}

model ProxyRequestLog {
  id                   String   @id @default(uuid())
  requestId            String   @unique
  userId               String?
  rentalId             String?
  apiKeyId             String?
  apiKeyPrefix         String?
  method               String
  path                 String
  model                String?
  statusCode           Int?
  upstreamStatusCode   Int?
  errorCode            String?
  durationMs           Int
  requestBytes         Int      @default(0)
  estimatedInputTokens Int      @default(0)
  ipAddress            String?
  userAgent            String?
  createdAt            DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  rental Rental? @relation(fields: [rentalId], references: [id], onDelete: SetNull)
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([rentalId, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([model, createdAt])
  @@index([statusCode, createdAt])
  @@index([errorCode, createdAt])
}

model Supplier {
  id               String   @id @default(uuid())
  userId           String   @unique
  displayName      String?
  status           String   @default("pending")
  defaultShareRate Decimal  @default(0.7) @db.Decimal(8, 4)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  resources   SupplierResource[]
  withdrawals Withdrawal[]
}

model SupplierResource {
  id             String                 @id @default(uuid())
  supplierId     String
  resourceType   ResourceType
  status         SupplierResourceStatus @default(pending)
  level          SupplierLevel          @default(L0)
  shareRate      Decimal                @default(0.7) @db.Decimal(8, 4)
  dailyCap       Decimal?               @db.Decimal(18, 6)
  reserveRatio   Decimal                @default(0.2) @db.Decimal(8, 4)
  maxConcurrency Int                    @default(1)
  sub2AccountId  String?
  lastCheckedAt  DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  supplier    Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  usages      UsageRecord[]
  settlements SettlementRecord[]
  credential  SupplierResourceCredential?
}

model SupplierResourceCredential {
  id                 String   @id @default(uuid())
  supplierResourceId String   @unique
  credentialType     String
  encryptedValue     String
  encryptionVersion  String   @default("aes-256-gcm:v1")
  keyFingerprint     String
  status             String   @default("active")
  lastRotatedAt      DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  supplierResource SupplierResource @relation(fields: [supplierResourceId], references: [id], onDelete: Cascade)
}

model UsageRecord {
  id                 String       @id @default(uuid())
  sub2RequestId      String       @unique
  rentalId           String
  userId             String
  supplierResourceId String?
  resourceType       ResourceType
  model              String?
  inputUnits         Decimal      @default(0) @db.Decimal(18, 6)
  outputUnits        Decimal      @default(0) @db.Decimal(18, 6)
  apiEquivalentCost  Decimal      @default(0) @db.Decimal(18, 6)
  buyerCharge        Decimal      @default(0) @db.Decimal(18, 6)
  supplierIncome     Decimal      @default(0) @db.Decimal(18, 6)
  status             UsageStatus  @default(pending)
  occurredAt         DateTime
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  rental           Rental             @relation(fields: [rentalId], references: [id], onDelete: Restrict)
  supplierResource SupplierResource?  @relation(fields: [supplierResourceId], references: [id], onDelete: SetNull)
  settlements      SettlementRecord[]
}

model BillingSyncState {
  id             String    @id
  cursor         String?
  lastStatus     String?
  lastError      String?
  lastImported   Int       @default(0)
  lastSkipped    Int       @default(0)
  lastUnmatched  Int       @default(0)
  lastStartedAt  DateTime?
  lastFinishedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model BillingSyncRun {
  id         String    @id @default(uuid())
  source     String
  cursorIn   String?
  cursorOut  String?
  status     String
  imported   Int       @default(0)
  skipped    Int       @default(0)
  unmatched  Int       @default(0)
  error      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([source, startedAt])
  @@index([status, startedAt])
}

model SettlementRecord {
  id                 String           @id @default(uuid())
  supplierResourceId String
  usageRecordId      String?
  amount             Decimal          @db.Decimal(18, 6)
  reservedAmount     Decimal          @default(0) @db.Decimal(18, 6)
  withdrawnAmount    Decimal          @default(0) @db.Decimal(18, 6)
  shareRate          Decimal          @db.Decimal(8, 4)
  status             SettlementStatus @default(pending)
  availableAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  supplierResource SupplierResource @relation(fields: [supplierResourceId], references: [id], onDelete: Restrict)
  usageRecord      UsageRecord?     @relation(fields: [usageRecordId], references: [id], onDelete: SetNull)
  withdrawals      WithdrawalSettlement[]
}

model Withdrawal {
  id         String           @id @default(uuid())
  supplierId String
  amount     Decimal          @db.Decimal(18, 6)
  currency   String           @default("USD")
  status     WithdrawalStatus @default(pending)
  payoutRef  String?
  note       String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  supplier    Supplier               @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  settlements WithdrawalSettlement[]
}

model WithdrawalSettlement {
  id                 String   @id @default(uuid())
  withdrawalId       String
  settlementRecordId String
  amount             Decimal  @db.Decimal(18, 6)
  status             String   @default("reserved")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  withdrawal       Withdrawal       @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)
  settlementRecord SettlementRecord @relation(fields: [settlementRecordId], references: [id], onDelete: Restrict)

  @@index([withdrawalId])
  @@index([settlementRecordId])
  @@index([status])
}

model Sub2Binding {
  id         String   @id @default(uuid())
  objectType String
  objectId   String
  sub2Type   String
  sub2Id     String
  meta       Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([objectType, objectId, sub2Type])
  @@unique([sub2Type, sub2Id])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  objectType  String
  objectId    String?
  before      Json?
  after       Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
}

model SystemHealthSnapshot {
  id          String   @id @default(uuid())
  status      String
  source      String   @default("manual")
  summary     Json
  checks      Json
  actorUserId String?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([source, createdAt])
  @@index([actorUserId, createdAt])
}
