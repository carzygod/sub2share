NODE_ENV=production
APP_NAME=智算驿站
APP_PUBLIC_URL=https://zhisuanyizhan.com
ADMIN_PUBLIC_URL=https://admin.zhisuanyizhan.com
API_PUBLIC_URL=https://api.zhisuanyizhan.com
OPENAI_PROXY_PUBLIC_ENDPOINT=https://api.zhisuanyizhan.com/v1

GOOGLE_OAUTH_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://api.zhisuanyizhan.com/api/auth/oauth/google/callback

X_OAUTH_CLIENT_ID=replace-with-x-oauth-client-id
X_OAUTH_CLIENT_SECRET=replace-with-x-oauth-client-secret
X_OAUTH_REDIRECT_URI=https://api.zhisuanyizhan.com/api/auth/oauth/x/callback

DATABASE_URL=postgresql://zhisuan:zhisuan@localhost:5432/zhisuan_user?schema=public
REDIS_URL=redis://localhost:6379/0
OAUTH_STATE_STORE=redis

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
API_KEY_ENCRYPTION_SECRET=replace-with-32-byte-secret

SUB2_BASE_URL=http://localhost:8080
SUB2_ADMIN_TOKEN=
SUB2_ADMIN_EMAIL=admin@example.com
SUB2_ADMIN_PASSWORD=replace-with-sub2-admin-password
SUB2_PUBLIC_ENDPOINT=http://localhost:8080/v1
SUB2_DEFAULT_GROUP_ID=
SUB2_SMOKE_MODEL=gpt-5.3-codex
SUB2_REQUEST_TIMEOUT_MS=30000
SUB2_REQUEST_RETRY_ATTEMPTS=2
SUB2_REQUEST_RETRY_BASE_MS=500
SUB2_USAGE_SYNC_INTERVAL_MS=60000
SUB2_USAGE_SYNC_ON_START=true
OPENAI_PROXY_BODY_LIMIT_BYTES=52428800
OPENAI_PROXY_UPSTREAM_TIMEOUT_MS=300000
OPENAI_PROXY_STREAM_IDLE_TIMEOUT_MS=300000
OPENAI_PROXY_MIN_WALLET_BALANCE=0
OPENAI_PROXY_LIMITER_STORE=redis

PAYMENT_PROVIDER=mock
MIN_RECHARGE_AMOUNT=10
MIN_WITHDRAWAL_AMOUNT=20
DEFAULT_DISCOUNT_RATE=0.2
